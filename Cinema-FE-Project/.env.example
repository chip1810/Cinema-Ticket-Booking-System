# API Configuration
BACKEND_URL=https://cinema-ticket-booking-system-3.onrender.com/api/v1
REACT_APP_API_TIMEOUT=30000

VITE_BASE_URL=https://cinema-ticket-booking-system-3.onrender.com

# App Configuration
REACT_APP_NAME=Cinema Management System
REACT_APP_VERSION=1.0.0

# Payment Configuration
REACT_APP_VNPAY_RETURN_URL=https://cinema-ticket-booking-system-3.onrender.com/payment/callback
REACT_APP_MOMO_RETURN_URL=https://cinema-ticket-booking-system-3.onrender.com/payment/momo-callback

# Feature Flags
REACT_APP_ENABLE_REGISTRATION=true
REACT_APP_ENABLE_LOYALTY_PROGRAM=true
REACT_APP_ENABLE_SOCIAL_LOGIN=false

# Image Upload
REACT_APP_MAX_IMAGE_SIZE=5242880
REACT_APP_CLOUDINARY_UPLOAD_PRESET=cinema_preset

# Booking Configuration
REACT_APP_SEAT_LOCK_DURATION=600000
REACT_APP_MAX_SEATS_PER_BOOKING=10

# Google Analytics (Optional)
REACT_APP_GA_TRACKING_ID=

# Sentry Error Tracking (Optional)
REACT_APP_SENTRY_DSN=
