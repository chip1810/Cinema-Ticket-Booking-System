# API Configuration (tùy chọn khi dev):
# - Để TRỐNG: FE dùng đường dẫn /api + proxy trong package.json → BE mặc định http://localhost:3000
# - Hoặc set đúng cổng backend, ví dụ BE chạy 5000:
#   REACT_APP_API_URL=http://localhost:5000/api
# KHÔNG đặt trùng cổng React (4200/3000 của npm start) — sẽ bị 404.
# Không dùng /api/v1 (backend không có prefix này).
REACT_APP_API_URL=
REACT_APP_API_TIMEOUT=30000

VITE_BASE_URL=http://localhost:3000

# App Configuration
REACT_APP_NAME=Cinema Management System
REACT_APP_VERSION=1.0.0

# Payment Configuration
REACT_APP_VNPAY_RETURN_URL=http://localhost:3000/payment/callback
REACT_APP_MOMO_RETURN_URL=http://localhost:3000/payment/momo-callback

# Feature Flags
REACT_APP_ENABLE_REGISTRATION=true
REACT_APP_ENABLE_LOYALTY_PROGRAM=true
REACT_APP_ENABLE_SOCIAL_LOGIN=false

# Image Upload
REACT_APP_MAX_IMAGE_SIZE=5242880
REACT_APP_CLOUDINARY_UPLOAD_PRESET=cinema_preset

# Booking Configuration
REACT_APP_SEAT_LOCK_DURATION=600000
REACT_APP_MAX_SEATS_PER_BOOKING=10

# Google Analytics (Optional)
REACT_APP_GA_TRACKING_ID=

# Sentry Error Tracking (Optional)
REACT_APP_SENTRY_DSN=
